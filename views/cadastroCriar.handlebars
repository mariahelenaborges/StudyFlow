<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>StudyFlow - Cadastro de Estudante</title>
    <style>
        body {
             font-family: 'Segoe UI', Arial, sans-serif; 
             background-color: #fcfbfe;
             display: flex; justify-content: center; 
            align-items: center; height: 100vh; margin: 0; 
        }
        .container-cadastro { 
        background: #ffffff;
        padding: 40px; 
        border-radius: 12px; 
        box-shadow: 0 8px 24px rgba(108, 92, 231, 0.08); 
        width: 100%; max-width: 400px; 
        border: 1px solid #f1f0f7; 
        }
        h2 { 
        margin-top: 0; 
        color: #0c6ab9; 
        font-size: 24px; 
        margin-bottom: 25px; 
        text-align: center; 
        }
        label {
         display: block; 
         margin-top: 15px; 
         font-weight: 600; 
         color: #444; 
         font-size: 14px; 
        }
        input { 
        width: 100%; 
        padding: 12px; 
        margin-top: 6px; 
        box-sizing: border-box; 
        border: 1px solid #ddd; 
        border-radius: 6px; 
        font-size: 14px; 
        background-color: #fafafa; 
        }
        .btn-submit { 
        background-color: #0c6ab9; 
        color: white; border: none; 
        padding: 14px; width: 100%; 
        font-weight: bold; 
        border-radius: 6px; 
        margin-top: 25px; 
        cursor: pointer; 
        font-size: 15px; }
        .voltar-link {
         display: block; 
         text-align: center;
         margin-top: 15px; 
         color: #888; 
         text-decoration: none; 
         font-size: 13px; 
         }
    </style>
</head>
<body>

    <div class="container-cadastro">
        <h2>Criar Conta</h2>
        <form action="/estudante/salvar" method="POST">
            <label for="nome">Nome Completo:</label>
            <input type="text" id="nome" name="nome" required placeholder="ex: Havana Queen Linda">

            <label for="email">E-mail Estudantil:</label>
            <input type="email" id="email" name="email" required placeholder="exemplo@gmail.com">

            <label for="curso">Curso / Área de Estudo:</label>
            <input type="text" id="curso" name="curso" placeholder="ex: Programação, PP2, ...">

            <button type="submit" class="btn-submit">Finalizar Cadastro</button>
        </form>
        <a href="/" class="voltar-link">Voltar para a página principal</a>
    </div>

</body>
</html>